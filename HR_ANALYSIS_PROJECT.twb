      <aliases enabled='yes' />
      <column caption='Total_Hired_Percentage' datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0635566352019456] / TOTAL([Calculation_0635566352019456])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Status' datatype='string' name='[Calculation_0277950584246272]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if isnull([Termdate]) then &apos;Hired&apos;&#13;&#10;else &apos;terminated&apos;&#13;&#10;end' />
      </column>
      <column caption='HIGHEST MAX' datatype='boolean' name='[Calculation_0277950592667649]' role='measure' type='nominal'>
        <calculation class='tableau' formula='WINDOW_MAX([Calculation_0635566352019456])=[Calculation_0635566352019456]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='RANK Top 2' datatype='boolean' name='[Calculation_0277950860836872]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK([Calculation_0635566352019456])&lt;=2'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Full Name' datatype='string' name='[Calculation_0277951025557516]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[First Name]+&apos; &apos;+[Last Name]' />
      </column>
      <column caption='Length of Hire' datatype='integer' name='[Calculation_0277951033040909]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Termdate]) &#13;&#10;THEN DATEDIFF(&apos;year&apos;,[Hiredate],TODAY())&#13;&#10;ELSE DATEDIFF(&apos;year&apos;,[Hiredate],[Termdate])&#13;&#10;END' />
      </column>
      <column caption='Total Hired' datatype='integer' name='[Calculation_0635566352019456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Employee_ID])' />
      </column>
      <column caption='Total Ternimated' datatype='integer' name='[Calculation_0635566352183297]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF NOT ISNULL([Termdate]) THEN [Employee_ID] END)' />
      </column>
      <column caption='Total Active' datatype='integer' name='[Calculation_0635566352875522]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF ISNULL([Termdate]) THEN  [Employee_ID] END)' />
      </column>
      <column caption='Location' datatype='string' name='[Calculation_0635566379425800]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [State]&#13;&#10;    when &apos;New York&apos; then &apos;HQ&apos;&#13;&#10;    else &apos;Branch&apos;&#13;&#10;END' />
      </column>
      <column caption='AGE' datatype='integer' name='[Calculation_0635566423949329]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;,[Birthdate],TODAY())' />
      </column>
      <column caption='AGE GROUPS' datatype='string' name='[Calculation_0635566424391698]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0635566423949329]&lt;25 THEN &apos;&lt;25&apos;&#13;&#10;ELSEIF [Calculation_0635566423949329]&gt;=25 AND [Calculation_0635566423949329]&lt;35 THEN &apos;25-34&apos;&#13;&#10;ELSEIF [Calculation_0635566423949329]&gt;=35 AND [Calculation_0635566423949329]&lt;45 THEN &apos;35-44&apos;&#13;&#10;ELSEIF [Calculation_0635566423949329]&gt;=45 AND [Calculation_0635566423949329]&lt;55 THEN &apos;45-54&apos;&#13;&#10;ELSEIF [Calculation_0635566423949329]&gt;=55  THEN &apos;55+&apos;&#13;&#10;END' />
      </column>
